{% extends 'base.html.twig' %}

{% block title %}Vérifiez vos e-mails{% endblock %}

{% block body %}
<div class="flex min-h-full">
    <div class="flex flex-1 flex-col justify-center px-4 py-12 sm:px-6 lg:flex-none lg:px-20 xl:px-24">
        <div class="mx-auto w-full max-w-sm lg:w-96">
            <div>
                <h1 class="text-2xl font-bold tracking-tight text-indigo-600">⛺ Camping</h1>
                <h2 class="mt-8 text-2xl font-bold tracking-tight text-gray-900">Vérifiez vos e-mails</h2>
            </div>

            <div class="mt-10 space-y-4 text-sm text-gray-500">
                <p>
                    Si un compte correspond à l'adresse saisie, un e-mail vient de vous être envoyé
                    avec un lien permettant de réinitialiser votre mot de passe. Ce lien expirera dans
                    {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
                </p>
                <p>
                    Si vous ne recevez pas d'e-mail, vérifiez votre dossier de courriers indésirables ou
                    <a href="{{ path('app_forgot_password_request') }}" class="font-semibold text-indigo-600 hover:text-indigo-500">réessayez</a>.
                </p>
            </div>

            <p class="mt-6 text-sm text-gray-500">
                <a href="{{ path('app_login') }}" class="font-semibold text-indigo-600 hover:text-indigo-500">Retour à la connexion</a>
            </p>
        </div>
    </div>
    <div class="relative hidden w-0 flex-1 lg:block">
        <img src="https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?auto=format&fit=crop&w=1908&q=80" alt="" class="absolute inset-0 size-full object-cover">
    </div>
</div>
{% endblock %}
